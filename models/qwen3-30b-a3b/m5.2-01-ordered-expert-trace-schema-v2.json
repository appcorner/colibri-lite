{
  "schema": "colibri-qwen3-moe-m5.2-01-ordered-expert-trace-v2",
  "schema_version": 2,
  "backward_compatibility": {
    "previous_schema": "colibri-qwen3-moe-m5.1-00-ordered-expert-trace-v1",
    "record_fields_preserved": true,
    "new_fields": ["fixture_id", "workload_class", "requested_generation_length", "seed", "decoding", "stop_conditions", "kv_cache", "cache_configuration", "counters"]
  },
  "encoding": "UTF-8 JSON object with compact separators and trailing newline",
  "header_required_fields": [
    "schema",
    "schema_version",
    "trace_id",
    "fixture_id",
    "workload_class",
    "classification",
    "baseline_id",
    "release_id",
    "release_tag",
    "baseline_runtime_source_commit",
    "trace_instrumentation_commit",
    "model_repository",
    "model_revision",
    "canonical_artifact_root_sha256",
    "tokenizer_identity",
    "input_token_ids",
    "expected_generated_token_ids",
    "requested_generation_length",
    "seed",
    "decoding",
    "stop_conditions",
    "kv_cache",
    "cache_configuration",
    "runtime_configuration",
    "counters",
    "serialization",
    "records"
  ],
  "record_required_fields": {
    "global_ordinal": "non-negative integer contiguous from zero per fixture trace",
    "fixture_id": "matches the trace header fixture_id",
    "phase": "prefill or decode",
    "generation_step": "non-negative integer",
    "decode_step": "null for prefill, non-negative integer for decode",
    "input_token_id": "non-negative integer",
    "absolute_position": "non-negative integer",
    "layer_index": "0..47",
    "selected_expert_rank": "0..7",
    "expert_id": "0..127",
    "layer_expert_key": "layer.<layer_index>.expert.<expert_id>",
    "payload_bytes": "positive integer matching canonical expert manifest",
    "cache_hit": "boolean",
    "loaded": "boolean",
    "evictions_caused": "non-negative integer"
  },
  "ordering": "records are actual ExpertStore request order; no post-hoc sorting or reconstruction",
  "canonical_exclusions": ["timestamp", "process_id", "local_filesystem_path", "timing"]
}
